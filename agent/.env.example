# Copy this file to .env in the same directory (agent/.env) before running the agent.
# From agent/: cp .env.example .env
#
# The agent loads, in order: ./.env then agent/.env (second helps if cwd is repo root).

# Gemini API key used by the ADK Gemini model.
GEMINI_API_KEY=

# Gemini model (optional).
AGENT_MODEL=gemini-3.1-flash-lite

# Gemini image generation model (optional).
AGENT_IMAGE_MODEL=gemini-3.1-flash-image-preview

# Maximum concurrent Gemini photo generations (optional - default is 3, max is 4).
AGENT_IMAGE_GENERATION_CONCURRENCY=3

# Directory where generated photos are written before recipes-cli attaches them.
AGENT_IMAGE_OUTPUT_DIR=/tmp/recipe-agent-images

# Markdown system prompt path (optional - default is prompts/recipe_copilot.md).
AGENT_INSTRUCTION_PATH=prompts/recipe_copilot.md

# HTTP bind address (optional - default is localhost:4100).
# AGENT_ADDR=localhost:4100

# PostgreSQL (used by recipes-cli when the agent calls it).
DB_HOST=localhost
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=recipes
